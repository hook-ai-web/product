# ── 카카오 ───────────────────────────────────────────
# https://developers.kakao.com → 내 애플리케이션 → 앱 키 → REST API 키
KAKAO_CLIENT_ID=

# ── 네이버 ───────────────────────────────────────────
# https://developers.naver.com → Application → 애플리케이션 등록
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ── 구글 ─────────────────────────────────────────────
# https://console.cloud.google.com → API 및 서비스 → 사용자 인증 정보
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── 이메일 인증 (SMTP) ────────────────────────────────
# 미설정시 개발 모드: 인증 코드를 서버 콘솔에 출력합니다
# 네이버: smtp.naver.com / 포트 465 (SSL)
# 구글 Gmail: smtp.gmail.com / 포트 587 (TLS)
EMAIL_HOST=
EMAIL_PORT=465
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=2막이음 <noreply@example.com>

# ── 서버 설정 ─────────────────────────────────────────
# 로컬 개발: http://localhost:3000 / 배포 후: 실제 도메인으로 변경
BASE_URL=http://localhost:3000
SESSION_SECRET=랜덤한_강력한_비밀키로_변경하세요
